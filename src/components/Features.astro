---
const features = [
  {
    title: "スコアシート自動作成",
    description:
      "組み合わせからスコアシートを自動生成。手書きの手間なく、印刷してすぐ使えます。",
    icon: "printer",
  },
  {
    title: "Excel一括インポート",
    description:
      "参加者リストをExcelファイルから一括登録。手入力の手間を大幅に削減します。",
    icon: "table",
  },
  {
    title: "賞状出力",
    description: "結果が出次第すぐ賞状を印刷できます。入賞者を待たせません。",
    icon: "award",
  },
  {
    title: "オフライン完結",
    description:
      "インターネット環境がない体育館でも安心。すべての機能がオフラインで動作します。",
    icon: "wifi-off",
  },
];
---

<section id="features" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">主な特徴</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        大会運営に必要な機能をひとつのアプリに集約しました
      </p>
    </div>

    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        features.map((feature) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 transition-shadow hover:shadow-lg">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-100 text-primary-600">
              {feature.icon === "wifi-off" && (
                <svg
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M1 1l22 22M16.72 11.06A10.94 10.94 0 0 1 19 12.55M5 12.55a10.94 10.94 0 0 1 5.17-2.39M10.71 5.05A16 16 0 0 1 22.56 9M1.42 9a15.91 15.91 0 0 1 4.7-2.88M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01" />
                </svg>
              )}
              {feature.icon === "award" && (
                <svg
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <circle cx="12" cy="8" r="6" />
                  <path d="M8.21 13.89L7 23l5-3 5 3-1.21-9.12" />
                </svg>
              )}
              {feature.icon === "table" && (
                <svg
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <rect x="3" y="3" width="18" height="18" rx="2" />
                  <path d="M3 9h18M3 15h18M9 3v18M15 3v18" />
                </svg>
              )}
              {feature.icon === "printer" && (
                <svg
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                  <rect x="6" y="14" width="12" height="8" />
                </svg>
              )}
            </div>
            <h3 class="mt-4 text-lg font-semibold text-slate-900">
              {feature.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
