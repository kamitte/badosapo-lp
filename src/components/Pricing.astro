---
interface Plan {
  name: string;
  price: string;
  period: string;
  description: string;
  featuresHeading?: string;
  features: string[];
  highlighted: boolean;
}

const plans: Plan[] = [
  {
    name: '無料プラン',
    price: '¥0',
    period: '',
    description: 'まずはお試しください',
    features: [
      '参加者数10人まで',
      '組み合わせ作成',
      'スコアシート印刷',
      '大会結果・順位表出力',
    ],
    highlighted: false,
  },
  {
    name: 'プレミアムプラン',
    price: '¥3,000',
    period: '/月',
    description: '大規模な大会を運営する方に',
    featuresHeading: '無料プランのすべての機能に加えて',
    features: [
      '参加者数無制限',
      '賞状印刷',
      '年額プラン: ¥16,000/年（¥20,000お得）',
    ],
    highlighted: true,
  },
];
---

<section id="pricing" class="bg-surface py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">料金プラン</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        まずは無料プランからお試しいただけます
      </p>
    </div>

    <div class="mx-auto mt-16 grid max-w-4xl gap-8 md:grid-cols-2">
      {plans.map((plan) => (
        <div
          class={`relative rounded-2xl border-2 p-8 ${
            plan.highlighted
              ? 'border-primary-600 bg-white shadow-xl'
              : 'border-slate-200 bg-white'
          }`}
        >
          {plan.highlighted && (
            <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-primary-600 px-4 py-1 text-xs font-semibold text-white">
              おすすめ
            </span>
          )}

          <h3 class="text-xl font-bold text-slate-900">{plan.name}</h3>
          <p class="mt-1 text-sm text-slate-500">{plan.description}</p>

          <div class="mt-6">
            <span class="text-4xl font-bold text-slate-900">{plan.price}</span>
            {plan.period && (
              <span class="text-lg text-slate-500">{plan.period}</span>
            )}
          </div>

          {plan.featuresHeading && (
            <p class="mt-8 text-sm font-semibold text-slate-700">{plan.featuresHeading}</p>
          )}
          <ul class={`space-y-3 ${plan.featuresHeading ? 'mt-4' : 'mt-8'}`}>
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-slate-600">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          {plan.highlighted && (
            <p class="mt-8 text-center text-xs text-slate-400">お支払い方法: 銀行振込</p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
