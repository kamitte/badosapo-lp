---
interface Category {
  title: string;
  icon: "players" | "event" | "format";
  items: string[];
}

const categories: Category[] = [
  {
    title: "大会種別",
    icon: "event",
    items: ["個人戦", "団体戦"],
  },
  {
    title: "試合形式",
    icon: "players",
    items: ["シングルス", "ダブルス", "トリプルス"],
  },

  {
    title: "進行方式",
    icon: "format",
    items: ["リーグ", "トーナメント", "リーグ→トーナメント"],
  },
];
---

<section id="formats" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">
        対応する種目
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        大会の目的や規模に合わせて、柔軟に種目を設定できます
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        categories.map((category) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center transition-shadow hover:shadow-lg">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-accent-500/10 text-accent-600">
              {category.icon === "event" && (
                <svg
                  class="h-8 w-8"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M7 4h10v4a5 5 0 01-10 0V4z" />
                  <path d="M7 6H4v1a3 3 0 003 3M17 6h3v1a3 3 0 01-3 3" />
                  <path d="M9 20h6M12 13v7" />
                </svg>
              )}
              {category.icon === "players" && (
                <svg
                  class="h-8 w-8"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="8" cy="8" r="2.5" />
                  <circle cx="16" cy="8" r="2.5" />
                  <path d="M3 19c0-2.761 2.239-5 5-5s5 2.239 5 5M11 19c0-2.761 2.239-5 5-5s5 2.239 5 5" />
                </svg>
              )}
              {category.icon === "format" && (
                <svg
                  class="h-8 w-8"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <rect x="3" y="3" width="18" height="18" rx="2" />
                  <path d="M3 9h18M9 3v18" />
                </svg>
              )}
            </div>
            <h3 class="mt-6 text-xl font-bold text-slate-900">
              {category.title}
            </h3>
            <ul class="mt-4 space-y-2">
              {category.items.map((item) => (
                <li class="text-sm text-slate-600">{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
