---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  heading: string;
  description?: string;
  updatedAt?: string;
}

const { title, heading, description, updatedAt } = Astro.props;
---

<Layout title={`${title} - バドサポ`} description={description}>
  <Header />
  <main class="bg-surface py-16 lg:py-20">
    <article class="mx-auto max-w-3xl px-4">
      <header class="border-b border-slate-200 pb-6">
        <h1 class="text-3xl font-bold text-slate-900 md:text-4xl">{heading}</h1>
        {updatedAt && (
          <p class="mt-3 text-sm text-slate-500">最終更新日: {updatedAt}</p>
        )}
      </header>

      <div class="legal-prose mt-10 text-slate-700">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style is:global>
  .legal-prose {
    line-height: 1.8;
  }
  .legal-prose h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e2e8f0;
  }
  .legal-prose h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .legal-prose p {
    margin-top: 1rem;
    margin-bottom: 1rem;
  }
  .legal-prose ul,
  .legal-prose ol {
    margin-top: 1rem;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .legal-prose ul {
    list-style: disc;
  }
  .legal-prose ol {
    list-style: decimal;
  }
  .legal-prose li {
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }
  .legal-prose li > ul,
  .legal-prose li > ol {
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }
  .legal-prose a {
    color: #2563eb;
    text-decoration: underline;
  }
  .legal-prose a:hover {
    color: #1d4ed8;
  }
  .legal-prose table {
    width: 100%;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    border-collapse: collapse;
  }
  .legal-prose th,
  .legal-prose td {
    border: 1px solid #e2e8f0;
    padding: 0.75rem 1rem;
    text-align: left;
    vertical-align: top;
  }
  .legal-prose th {
    background-color: #f1f5f9;
    font-weight: 600;
    color: #0f172a;
    white-space: nowrap;
    width: 12rem;
  }
  .legal-prose strong {
    color: #0f172a;
    font-weight: 600;
  }
</style>
